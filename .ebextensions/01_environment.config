option_settings:
  aws:elasticbeanstalk:container:python:
    WSGIPath: app:app
  aws:elasticbeanstalk:environment:proxy:staticfiles:
    /static: static
  aws:elasticbeanstalk:application:environment:
    FLASK_DEBUG: "False"
    PORT: "8000"
    AWS_REGION: "us-east-1"
    # FLASK_SECRET_KEY → set this in EB Console → Configuration → Environment properties
    # Do NOT put it here — this file is committed to git
